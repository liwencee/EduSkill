{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "EduSkill Web (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/web",
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "EduSkill API (Node.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "port": 3001,
      "autoPort": true,
      "env": {
        "PORT": "3001"
      }
    }
  ]
}
