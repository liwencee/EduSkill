# Server
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# OpenAI (EduPro lesson plan generator)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# Paystack (payments)
PAYSTACK_SECRET_KEY=sk_live_your-paystack-secret
PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public

# Twilio WhatsApp bot
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3001,https://skillbridge.ng

# Logging
LOG_LEVEL=info
